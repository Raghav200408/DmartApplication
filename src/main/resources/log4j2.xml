<?xml version="1.0" encoding="UTF-8"?>

<Configuration>

    <Appenders>

        <Console name="Console">

            <PatternLayout
                pattern="%d{yyyy-MM-dd HH:mm:ss} %-5level %c - %msg%n"/>

        </Console>

        <File
            name="File"
            fileName="C:/DmartLogs/dmart.log">

            <PatternLayout
                pattern="%d{yyyy-MM-dd HH:mm:ss} %-5level %c - %msg%n"/>

        </File>

    </Appenders>

    <Loggers>

        <Root level="info">

            <AppenderRef ref="Console"/>

            <AppenderRef ref="File"/>

        </Root>

    </Loggers>

</Configuration>